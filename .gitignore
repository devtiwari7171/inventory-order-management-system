# Root .gitignore

# Environment files (NEVER commit secrets)
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
backend/.venv/
backend/venv/

# Node
node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.bak

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Docker
.arena/

# Coverage / build artifacts
*.log
coverage/
dist/
build/
